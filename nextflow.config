// ── Default parameters ──────────────────────────────────────────────────────
params {
    samplesheet        = null
    outdir             = "results"
    upload_microreact  = false
    microreact_project = "sonnei-typer run"
    run_pathogenwatch = false
    pathogenwatch_collection_name = null
    pathogenwatch_cluster_threshold = 10
    pathogenwatch_poll_seconds = 60
    pathogenwatch_max_wait_seconds = 1800
}

// ── Publish outputs ─────────────────────────────────────────────────────────
process {
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: 'copy',
        saveAs: { filename -> filename.startsWith("NO_FILE") ? null : filename }
    ]

    // Resource labels
    withLabel: 'low' {
        cpus   = 2
        memory = '4 GB'
        time   = '1h'
    }
    withLabel: 'medium' {
        cpus   = 8
        memory = '16 GB'
        time   = '4h'
    }

    // Per-process error handling: tolerate tool failures, never abort the run
    errorStrategy = { task.exitStatus in [1, 2, 14] ? 'ignore' : 'terminate' }
}

// ── Profiles ─────────────────────────────────────────────────────────────────
profiles {

    // ── Local Mac / Linux with conda ────────────────────────────────────────
    conda {
        conda.enabled    = true
        conda.useMamba   = false   // set true if mamba is installed (faster)
        process.cpus     = 4
        process.memory   = '8 GB'
    }

    // ── Local Mac / Windows with Docker Desktop ─────────────────────────────
    docker {
        docker.enabled      = true
        docker.fixOwnership = true   // needed on Windows Docker Desktop
        docker.runOptions   = '-u $(id -u):$(id -g)'
        process.cpus        = 4
        process.memory      = '8 GB'
    }

    // ── HPC with Singularity / Apptainer ────────────────────────────────────
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.cacheDir   = "${HOME}/.singularity/cache"
        // On M3 (Monash HPC) override cacheDir in your run command or here:
        // singularity.cacheDir = "/home/ebenezef/js66_scratch/ebenn/singularity_cache"
    }

    // ── SLURM executor (combine with singularity: -profile singularity,slurm)
    slurm {
        process.executor = 'slurm'
        process.queue    = 'comp'    // adjust per HPC site
        // process.clusterOptions = '--account=js66'   // uncomment for M3
        withLabel: 'low' {
            cpus   = 2
            memory = '4 GB'
            time   = '1h'
        }
        withLabel: 'medium' {
            cpus   = 8
            memory = '16 GB'
            time   = '4h'
        }
    }

    // ── PBS / Torque executor ────────────────────────────────────────────────
    pbs {
        process.executor = 'pbs'
        process.queue    = 'normal'
        withLabel: 'low' {
            cpus   = 2
            memory = '4 GB'
            time   = '1h'
        }
        withLabel: 'medium' {
            cpus   = 8
            memory = '16 GB'
            time   = '4h'
        }
    }

    // ── Test profile (no Microreact upload) ──────────────────────────────────
    test {
        params.samplesheet       = "${projectDir}/test/samplesheet.csv"
        params.outdir            = "test_results"
        params.upload_microreact = false
    }
}

// ── Nextflow secrets (Microreact token) ─────────────────────────────────────
// Set once with: nextflow secrets set MICROREACT_TOKEN <your_token>
// The upload module reads it as an environment variable.

// ── Reporting ────────────────────────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}
